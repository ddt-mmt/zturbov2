# --- SETUP ---
# Detect if we're in the source repo or installed. If lib/config.sh exists here, use it.
if [[ -f "lib/config.sh" ]]; then
    source "lib/config.sh"
    source "lib/utils.sh"
    source "lib/ui.sh"
    source "lib/engine.sh"
else
    source "/usr/lib/zturbo_v2/config.sh"
    source "/usr/lib/zturbo_v2/utils.sh"
    source "/usr/lib/zturbo_v2/ui.sh"
    source "/usr/lib/zturbo_v2/engine.sh"
fi

# Inisialisasi awal
# RAM Disk creation needs careful error checking
mkdir -p "$DASHBOARD_DIR" "$REPORT_DIR"
chmod 777 "$DASHBOARD_DIR" 2>/dev/null
chmod 700 "$REPORT_DIR" 2>/dev/null
if [[ -n "$SUDO_USER" ]]; then REAL_USER="$SUDO_USER"; else REAL_USER="$USER"; fi
export JOB_ID="${REAL_USER}_$$"
export JOB_DIR="${DASHBOARD_DIR}/${JOB_ID}"
export BROWSER_DIR="/dev/shm/zturbo_browser_$$"
export CURRENT_SIZE_CALC_PID=""
export JOB_INFO_FILE="${JOB_DIR}/info"
export JOB_STATUS_FILE="${JOB_DIR}/status"
export JOB_PID_FILE="${JOB_DIR}/pid"
export REPORT_TXT="${REPORT_DIR}/${REAL_USER}_job$$.txt"
JOB_COMPLETED=false

check_deps
init_job_dir
trap cleanup EXIT
trap "exit 1" INT TERM

# --- MAIN LOGIC ---
STEP=1
while true; do
    if [[ $STEP -eq 1 ]]; then
        select_source || exit 0
        if [[ ${#SELECTED_PATHS[@]} -eq 1 ]]; then 
            SUGGESTED_NAME=$(basename "${SELECTED_PATHS[0]}")
        else 
            SUGGESTED_NAME="Batch_Transfer_$(date +%H%M)"
        fi
        SUB_FOLDER="$SUGGESTED_NAME"
        STEP=2
    fi

    if [[ $STEP -eq 2 ]]; then
        select_dest
        if [[ $? -eq 1 ]]; then STEP=1; continue; fi
        STEP=3
    fi

    if [[ $STEP -eq 3 ]]; then
        # --- FINAL CONFIRMATION ---
        while true; do
            REC_THREADS=$(calc_optimal_threads "$CURRENT_MODE")
            if [[ -z "$MANUAL_THREADS" ]]; then THREADS=$REC_THREADS; fi
            if [[ "$CURRENT_MODE" == "SAFE" ]]; then MODE_MSG="${BOLD_GREEN}SAFE${NC}"; else MODE_MSG="${BOLD_RED}TURBO${NC}"; fi
            
            if [[ "$SUB_FOLDER" == "." ]]; then DEST="${DEST_ROOT%/}/"
            else DEST="${DEST_ROOT%/}/$SUB_FOLDER"; fi

            print_header
            echo -e "${BOLD_YELLOW}[ FINAL CONFIRMATION ]${NC}"
            echo -e " [1] SOURCE  : ${BOLD_WHITE}${SELECTED_PATHS[0]}${NC} $([ ${#SELECTED_PATHS[@]} -gt 1 ] && echo "(and $(( ${#SELECTED_PATHS[@]} - 1 )) others)")"
            echo -e " [2] DEST    : $DEST_ROOT"
            echo -e " [3] FOLDER  : $SUB_FOLDER"
            echo -e " [4] THREADS : ${BOLD_WHITE}$THREADS${NC} (Rec: $REC_THREADS) $MODE_MSG"
            echo -e " [5] MODE    : $CURRENT_MODE"
            echo -e "------------------------------------------"
            echo -e " TARGET      : ${BOLD_GREEN}$DEST${NC}"
            echo -e "------------------------------------------"
            echo -e " ${BOLD_RED}⚠️  To START, Type 'OK' and Press Enter.${NC}"
            show_footer "Type 'OK' | [1-5] Edit | [B] Back"
            
            read -e k || exit 1
                                
            if [[ "${k^^}" == "OK" ]]; then
                echo ">> Calculating Source Metadata (Please Wait)..."
                calculate_total_source_size
                write_job_info
                break 2
            fi

            case "${k^^}" in
                Q) exit 0 ;;
                B) STEP=2; break ;;
                1) select_source ;;
                2) select_dest ;;
                3) read -e -p "New Folder Name: " -i "$SUB_FOLDER" SUB_FOLDER ;; 
                4) read -e -p " Set Threads manually: " MANUAL_THREADS || exit 1 ;; 
                5) [[ "$CURRENT_MODE" == "SAFE" ]] && CURRENT_MODE="TURBO" || CURRENT_MODE="SAFE" ;;
            esac
        done
        if [[ $STEP -ne 3 ]]; then continue; fi
    fi
done

# --- EXECUTION ---
print_header
echo -e "\n${BOLD_CYAN}🚀 INITIALIZING TRANSFER...${NC}"
echo "   (You can now run 'zmturbo' in another terminal to monitor progress)"

START_TIME=$(date +%s); START_DATE=$(date)
cat <<EOF > "$REPORT_TXT"
================================================================
              ZTURBO TRANSFER REPORT
================================================================
JOB ID      : $JOB_ID
USER        : $REAL_USER
DATE        : $START_DATE
----------------------------------------------------------------
DESTINATION : $DEST
MODE        : $CURRENT_MODE (Threads: $THREADS)
SOURCES     :
EOF
for s in "${SELECTED_PATHS[@]}"; do echo " - $s" >> "$REPORT_TXT"; done
echo "================================================================" >> "$REPORT_TXT"

main_execution

# --- VERIFICATION ---
post_execution_verification
